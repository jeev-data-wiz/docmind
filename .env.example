# DocMind AI Agent — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control.

# ── Required: Choose ONE LLM provider ─────────────────────────────────────────

# Option A: Anthropic (default, recommended)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-haiku-20241022

# Option B: OpenAI (comment out Option A and uncomment this)
# OPENAI_API_KEY=your_openai_api_key_here
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini

# ── Embeddings (default: local, no API key needed) ─────────────────────────────
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# To use OpenAI embeddings instead (higher quality, costs money):
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_KEY=your_openai_api_key_here   # same key as above if using OpenAI LLM

# ── Storage paths ──────────────────────────────────────────────────────────────
VECTOR_STORE_PATH=.vectorstore

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
